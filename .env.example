# ko-pellet Configuration
# ======================
# Copy this file to .env and configure your settings

# KitchenOwl Connection
# ---------------------
# URL of your KitchenOwl instance (required)
KITCHENOWL_URL=https://kitchenowl.example.com

# OIDC Authentication (option 1)
# ------------------------------
# Configure these to enable OIDC login (Keycloak, Authentik, etc.)
OIDC_ISSUER=https://keycloak.example.com/realms/myrealm
OIDC_CLIENT_ID=ko-pellet
OIDC_CLIENT_SECRET=your-client-secret-here

# Forward-Auth (option 2)
# -----------------------
# Enable if using a reverse proxy with forward-auth (Authelia, Authentik)
# When enabled, user identity is read from proxy headers instead of OIDC
FORWARD_AUTH_ENABLED=false
FORWARD_AUTH_HEADER_USER=Remote-User

# Trusted Proxy IPs (REQUIRED for forward-auth)
# ----------------------------------------------
# SECURITY: When using forward-auth, you MUST set this to prevent header spoofing.
# Only requests from these IPs/CIDRs will have auth headers trusted.
# Supports single IPs and CIDR notation.
# Examples:
#   TRUSTED_PROXY_IPS=172.17.0.1
#   TRUSTED_PROXY_IPS=172.18.0.0/16
#   TRUSTED_PROXY_IPS=192.168.1.1,10.0.0.0/8
#TRUSTED_PROXY_IPS=

# App URL
# -------
# Public URL of this application (used for OIDC redirect)
# Default port is 8998
APP_URL=https://recipes.example.com

# Session Secret (optional)
# -------------------------
# If not provided, a random key is generated on first run
# Generate with: openssl rand -base64 32
#SECRET_KEY=

# Debug Mode (optional)
# ---------------------
DEBUG=false

# Internal Hosts Allowlist (optional)
# -----------------------------------
# If you want to import recipes from URLs on your local network,
# add those hostnames or IPs here (comma-separated).
# Example: ALLOWED_INTERNAL_HOSTS=recipes.local,ko.lan,192.168.1.100
#ALLOWED_INTERNAL_HOSTS=

# ============================================
# CUSTOM CA CERTIFICATES
# ============================================
# If your KitchenOwl, OIDC provider, or AI APIs use certificates
# signed by a private/internal CA, place your CA certificate(s)
# in the ./certs/ directory (next to this file):
#
#   mkdir certs
#   cp /path/to/my-internal-ca.crt certs/
#
# The container will automatically trust these on startup.
# Supports multiple .crt files.

# ============================================
# SECRETS CONFIGURED VIA WEB UI AFTER LOGIN
# ============================================
# The following secrets are now configured through the web interface
# after logging in, and stored encrypted on disk:
#
# - KITCHENOWL_TOKEN: Long-lived API token from KitchenOwl
# - ANTHROPIC_API_KEY: For AI-powered recipe parsing
# - OPENAI_API_KEY: Alternative AI provider
#
# On first run, existing environment variables will be automatically
# migrated to encrypted storage.
